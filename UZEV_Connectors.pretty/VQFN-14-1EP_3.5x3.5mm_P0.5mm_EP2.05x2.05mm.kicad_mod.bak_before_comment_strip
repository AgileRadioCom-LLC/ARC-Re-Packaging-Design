(module VQFN-14-1EP_3.5x3.5mm_P0.5mm_EP2.05x2.05mm (layer F.Cu) (tedit 5F000000)
  (descr "VQFN-14 EP 2.05x2.05mm, 3.5x3.5mm body, 0.5mm pitch; TI RHL0014A (TPS54320); tps54320.pdf pp.40-41")
  (tags "QFN VQFN 14 EP 3.5x3.5 TPS54320")
  (attr smd)
  (fp_text reference REF** (at 0 -2.6) (layer F.SilkS)
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value VQFN-14-1EP_3.5x3.5mm_P0.5mm_EP2.05x2.05mm (at 0 2.6) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.15)))
  )

  ;; F.Fab body outline 3.5x3.5mm (±1.75mm)
  ;; Pin 1 chamfer at top-left corner (0.3mm per tps54320.pdf p.40)
  (fp_line (start -1.75 -1.45) (end -1.45 -1.75) (layer F.Fab) (width 0.1))
  (fp_line (start -1.45 -1.75) (end 1.75 -1.75) (layer F.Fab) (width 0.1))
  (fp_line (start 1.75 -1.75) (end 1.75 1.75) (layer F.Fab) (width 0.1))
  (fp_line (start 1.75 1.75) (end -1.75 1.75) (layer F.Fab) (width 0.1))
  (fp_line (start -1.75 1.75) (end -1.75 -1.45) (layer F.Fab) (width 0.1))

  ;; F.SilkS corner marks (L-shaped, avoiding pads)
  (fp_line (start -2.2 -2.2) (end -2.2 -1.8) (layer F.SilkS) (width 0.12))
  (fp_line (start -2.2 -2.2) (end -1.8 -2.2) (layer F.SilkS) (width 0.12))
  (fp_line (start 2.2 -2.2) (end 2.2 -1.8) (layer F.SilkS) (width 0.12))
  (fp_line (start 2.2 -2.2) (end 1.8 -2.2) (layer F.SilkS) (width 0.12))
  (fp_line (start -2.2 2.2) (end -2.2 1.8) (layer F.SilkS) (width 0.12))
  (fp_line (start -2.2 2.2) (end -1.8 2.2) (layer F.SilkS) (width 0.12))
  (fp_line (start 2.2 2.2) (end 2.2 1.8) (layer F.SilkS) (width 0.12))
  (fp_line (start 2.2 2.2) (end 1.8 2.2) (layer F.SilkS) (width 0.12))

  ;; F.SilkS pin 1 indicator dot
  (fp_circle (center -2.0 -2.0) (end -1.85 -2.0) (layer F.SilkS) (width 0.12))

  ;; F.CrtYd courtyard (body 3.5mm + 0.5mm clearance each side = ±2.25mm)
  (fp_line (start -2.25 -2.25) (end 2.25 -2.25) (layer F.CrtYd) (width 0.05))
  (fp_line (start 2.25 -2.25) (end 2.25 2.25) (layer F.CrtYd) (width 0.05))
  (fp_line (start 2.25 2.25) (end -2.25 2.25) (layer F.CrtYd) (width 0.05))
  (fp_line (start -2.25 2.25) (end -2.25 -2.25) (layer F.CrtYd) (width 0.05))

  ;; EP pad 15: 2.05x2.05mm copper+mask (no paste — segmented paste pads below)
  (pad 15 smd roundrect (at 0 0) (size 2.05 2.05) (layers F.Cu F.Mask) (roundrect_rratio 0.1))

  ;; EP segmented paste pads (4 quadrants, ~0.75mm sq each, 0.2mm gap)
  (pad "" smd roundrect (at -0.475 -0.475) (size 0.75 0.75) (layers F.Paste) (roundrect_rratio 0.25))
  (pad "" smd roundrect (at 0.475 -0.475) (size 0.75 0.75) (layers F.Paste) (roundrect_rratio 0.25))
  (pad "" smd roundrect (at -0.475 0.475) (size 0.75 0.75) (layers F.Paste) (roundrect_rratio 0.25))
  (pad "" smd roundrect (at 0.475 0.475) (size 0.75 0.75) (layers F.Paste) (roundrect_rratio 0.25))

  ;; Top row (pins 1, 14): Y=-1.65mm, X=±0.75mm, size=(0.24, 0.6)
  ;; Pin 1 at top-left (X=-0.75), pin 14 at top-right (X=+0.75)
  (pad 1 smd roundrect (at -0.75 -1.65) (size 0.24 0.6) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 14 smd roundrect (at 0.75 -1.65) (size 0.24 0.6) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))

  ;; Left column (pins 2-6): X=-1.65mm, Y=-1.0 to +1.0mm in 0.5mm steps (top to bottom = CCW)
  (pad 2 smd roundrect (at -1.65 -1.0) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 3 smd roundrect (at -1.65 -0.5) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 4 smd roundrect (at -1.65 0) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 5 smd roundrect (at -1.65 0.5) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 6 smd roundrect (at -1.65 1.0) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))

  ;; Bottom row (pins 7, 8): Y=+1.65mm, X=+0.75 to -0.75mm (CCW: right to left)
  (pad 7 smd roundrect (at 0.75 1.65) (size 0.24 0.6) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 8 smd roundrect (at -0.75 1.65) (size 0.24 0.6) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))

  ;; Right column (pins 9-13): X=+1.65mm, Y=+1.0 to -1.0mm in 0.5mm steps (CCW: bottom to top)
  (pad 9 smd roundrect (at 1.65 1.0) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 10 smd roundrect (at 1.65 0.5) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 11 smd roundrect (at 1.65 0) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 12 smd roundrect (at 1.65 -0.5) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
  (pad 13 smd roundrect (at 1.65 -1.0) (size 0.6 0.24) (layers F.Cu F.Mask F.Paste) (roundrect_rratio 0.25))
)
